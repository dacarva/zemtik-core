# Database backend: "sqlite" (default) or "supabase"
DB_BACKEND=sqlite

# Required when DB_BACKEND=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional (Supabase bootstrap behavior)
# - Set to 0 to skip the direct Postgres DDL step (table must already exist)
SUPABASE_AUTO_CREATE_TABLE=1
# - Set to 0 to skip inserting the 500 demo transactions
SUPABASE_AUTO_SEED=1

# Required for the OpenAI advisory step (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# --- Multi-model LLM backend (v0.16+) ---
# Default provider is "openai". Set to "anthropic" or "gemini" to use a different backend.
# ZEMTIK_LLM_PROVIDER=openai

# Required when ZEMTIK_LLM_PROVIDER=anthropic (https://console.anthropic.com/settings/keys)
# ZEMTIK_ANTHROPIC_API_KEY=

# Claude model to use when provider=anthropic. Defaults to claude-sonnet-4-6.
# ZEMTIK_ANTHROPIC_MODEL=claude-sonnet-4-6

# Override Anthropic API base URL (useful for local testing with a mock server).
# ZEMTIK_ANTHROPIC_BASE_URL=https://api.anthropic.com

# Required when ZEMTIK_LLM_PROVIDER=gemini (https://aistudio.google.com/app/apikey)
# ZEMTIK_GEMINI_API_KEY=

# Gemini model to use when provider=gemini. Defaults to gemini-2.5-flash.
# ZEMTIK_GEMINI_MODEL=gemini-2.5-flash

# Override Gemini API base URL (useful for local testing with a mock server).
# ZEMTIK_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional: Bearer key required on all inbound /v1/chat/completions requests.
# When set, requests missing Authorization: Bearer <key> are rejected with 401.
# Required when ZEMTIK_LLM_PROVIDER=anthropic or gemini (keeps provider key server-side).
# ZEMTIK_PROXY_API_KEY=

# Seconds before bb verify is abandoned (process is not killed in v0.5.1 — see TODOS.md)
# Set to 0 or leave unset to use the default (120s)
ZEMTIK_VERIFY_TIMEOUT_SECS=120

# Tunnel mode (ZEMTIK_MODE=tunnel)
# Required: API key for zemtik's verification calls (billed to zemtik, not the pilot customer).
ZEMTIK_TUNNEL_API_KEY=

# Optional: set to 1 to store 500-char plaintext previews of original LLM responses in the audit DB.
# Default: 0 (off) — previews are omitted in production to avoid persisting customer LLM output.
ZEMTIK_TUNNEL_DEBUG_PREVIEWS=0

# --- Anonymizer v1 (Phase 1) ---
# ZEMTIK_ANONYMIZER_ENABLED=false
# ZEMTIK_ANONYMIZER_SIDECAR_ADDR=http://127.0.0.1:50051
# ZEMTIK_ANONYMIZER_FALLBACK_REGEX=true
# ZEMTIK_ANONYMIZER_ENTITY_TYPES=PERSON,ORG,LOCATION
# ZEMTIK_ANONYMIZER_SIDECAR_TIMEOUT_MS=1500
# ZEMTIK_ANONYMIZER_DEBUG_PREVIEW=false
# ZEMTIK_ANONYMIZER_VAULT_TTL_SECS=300
