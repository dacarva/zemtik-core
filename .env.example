# Database backend: "sqlite" (default) or "supabase"
DB_BACKEND=sqlite

# Required when DB_BACKEND=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional (Supabase bootstrap behavior)
# - Set to 0 to skip the direct Postgres DDL step (table must already exist)
SUPABASE_AUTO_CREATE_TABLE=1
# - Set to 0 to skip inserting the 500 demo transactions
SUPABASE_AUTO_SEED=1

# Required for the OpenAI advisory step (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Seconds before bb verify is abandoned (process is not killed in v0.5.1 — see TODOS.md)
# Set to 0 or leave unset to use the default (120s)
ZEMTIK_VERIFY_TIMEOUT_SECS=120

# Tunnel mode (ZEMTIK_MODE=tunnel)
# Required: API key for zemtik's verification calls (billed to zemtik, not the pilot customer).
ZEMTIK_TUNNEL_API_KEY=

# Optional: set to 1 to store 500-char plaintext previews of original LLM responses in the audit DB.
# Default: 0 (off) — previews are omitted in production to avoid persisting customer LLM output.
ZEMTIK_TUNNEL_DEBUG_PREVIEWS=0
